<% weeks = month_weeks(year, month) %>
<% first_of_month = Date.new(year, month, 1) %>

<article class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
  <h3 class="mb-3 text-base font-semibold text-gray-900">
    <%= I18n.l(first_of_month, format: "%B") %>
  </h3>

  <div class="grid grid-cols-7 gap-1 text-center text-xs">
    <% %w[Mo Tu We Th Fr Sa Su].each do |label| %>
      <div class="py-1 font-medium uppercase tracking-wide text-gray-500" aria-hidden="true"><%= label %></div>
    <% end %>

    <% weeks.flatten.each do |date| %>
      <% in_month = date.month == month %>
      <% holidays = in_month ? holidays_by_date[date] : nil %>
      <% holiday_label = holidays && "Public holiday: #{holidays.map(&:local_name).join(' • ')}" %>
      <time
        datetime="<%= date.iso8601 %>"
        class="aspect-square rounded text-sm flex flex-col items-center justify-center gap-0.5
               <%= in_month ? 'text-gray-900' : 'text-gray-500' %>
               <%= holidays ? 'bg-amber-200 font-semibold ring-1 ring-amber-500' : '' %>"
        <% if holidays %>title="<%= holidays.map(&:local_name).join(' • ') %>"<% end %>
        <% unless in_month %>aria-hidden="true"<% end %>
      >
        <span><%= date.day %></span>
        <% if holidays %>
          <span class="block h-1 w-1 rounded-full bg-amber-700" aria-hidden="true"></span>
          <span class="sr-only"><%= holiday_label %></span>
        <% end %>
      </time>
    <% end %>
  </div>
</article>
